        self.screenshot_min_interval_sec = int(data.get("screenshot_min_interval_sec", 60))
        self.screenshot_timer_interval_sec = int(data.get("screenshot_timer_interval_sec", 60))
        self.screenshot_slowdown_interval_sec = int(data.get("screenshot_slowdown_interval_sec", 600))
        slow = data.get("screenshot_slowdown_exes")
        if isinstance(slow, list):
            self.screenshot_slowdown_exes = [str(e).lower() for e in slow if e]
        self.screenshot_quality     = int(data.get("screenshot_quality", 70))
        self.screenshot_downscale_pct = int(data.get("screenshot_downscale_pct", 100))
        if self.screenshot_downscale_pct < 25:
