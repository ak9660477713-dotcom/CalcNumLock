    """
    Редактирование плоского списка exe (без категорий).
    Используется для списка ВКС/медиа-приложений (замедление) и для
    списка исключений из скриншотов.
    """
    def __init__(self, title: str, hint: str, exes: list, parent=None):
        super().__init__(parent)
        self.setWindowTitle(title)
        self.setWindowFlags(self.windowFlags() | Qt.WindowStaysOnTopHint)
        self.setMinimumSize(420, 360)
        self.setStyleSheet(DIALOG_QSS)

        self.result_exes = list(exes)

        lay = QVBoxLayout(self)
        lay.setContentsMargins(16, 16, 16, 16)
        lay.setSpacing(10)

        if hint:
            lbl = QLabel(hint)
            lbl.setWordWrap(True)
            lbl.setStyleSheet("color:#aaa; font-size:11px;")
            lay.addWidget(lbl)

        self.table = QTableWidget(0, 2)
        self.table.setHorizontalHeaderLabels(["exe", ""])
        self.table.horizontalHeader().setSectionResizeMode(0, QHeaderView.Stretch)
        self.table.horizontalHeader().setSectionResizeMode(1, QHeaderView.ResizeToContents)
        self.table.verticalHeader().setVisible(False)
        self.table.setEditTriggers(QAbstractItemView.NoEditTriggers)
        lay.addWidget(self.table)

        for exe in sorted(set(e.lower() for e in exes)):
            self._add_row(exe)

        add_row = QHBoxLayout()
        self.inp_exe = QLineEdit()
        self.inp_exe.setPlaceholderText("например, zoom.exe")
        self.inp_exe.returnPressed.connect(self._on_add)
        btn_add = QPushButton("+ Добавить")
        btn_add.clicked.connect(self._on_add)
        add_row.addWidget(self.inp_exe, 1)
        add_row.addWidget(btn_add)
        lay.addLayout(add_row)

        btn_row = QHBoxLayout()
        btn_row.addStretch()
        b_cancel = QPushButton("Отмена")
        b_cancel.clicked.connect(self.reject)
        b_save = QPushButton("Сохранить")
        b_save.clicked.connect(self._on_save)
        btn_row.addWidget(b_cancel)
        btn_row.addWidget(b_save)
        lay.addLayout(btn_row)

    def _add_row(self, exe: str):
        r = self.table.rowCount()
        self.table.insertRow(r)
        self.table.setItem(r, 0, QTableWidgetItem(exe))
        btn_del = QPushButton("×")
        btn_del.setFixedWidth(28)
        btn_del.clicked.connect(self._on_delete)
        self.table.setCellWidget(r, 1, btn_del)

    def _on_add(self):
        exe = self.inp_exe.text().strip().lower()
        if not exe:
            return
        if not exe.endswith(".exe"):
            exe += ".exe"
        for r in range(self.table.rowCount()):
            if self.table.item(r, 0).text() == exe:
                QMessageBox.information(self, APP_NAME, f"{exe} уже в списке")
                return
        self._add_row(exe)
        self.inp_exe.clear()

    def _on_delete(self):
        sender = self.sender()
        for r in range(self.table.rowCount()):
            if self.table.cellWidget(r, 1) is sender:
                self.table.removeRow(r)
                return

    def _on_save(self):
        out = []
        for r in range(self.table.rowCount()):
            exe = self.table.item(r, 0).text().strip().lower()
            if exe:
                out.append(exe)
        self.result_exes = sorted(set(out))
        self.accept()


