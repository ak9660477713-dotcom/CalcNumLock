                self._export_csv(dlg.result_from, dlg.result_to, Path(dlg.result_path))
            else:
                self._export_html(dlg.result_from, dlg.result_to, Path(dlg.result_path))
            QMessageBox.information(self, APP_NAME,
                                    f"Сохранено: {Path(dlg.result_path).name}")
        except Exception as e:
            log(f"Export failed: {e}")
            QMessageBox.critical(self, APP_NAME, f"Ошибка экспорта: {e}")

    # ------------------------------------------------------------------
    # Экспорт (с поддержкой старого формата без колонки context)
    # ------------------------------------------------------------------
    def _iter_rows(self, d1: date, d2: date):
        cur = d1
        while cur <= d2:
            p = self.activity_csv_path(cur)
            if p.exists():
                try:
                    with open(p, "r", encoding="utf-8", newline="") as f:
                        r = csv.DictReader(f)
                        for row in r:
                            # если в старом файле нет колонки context, добавим пустую
                            if "context" not in row:
                                row["context"] = ""
                            yield row
                except Exception:
                    pass
            cur += timedelta(days=1)

    def _export_csv(self, d1: date, d2: date, out: Path):
        with open(out, "w", newline="", encoding="utf-8") as f:
            w = csv.writer(f)
            w.writerow(["start", "end", "duration_sec", "exe", "category", "idle", "context"])
            for row in self._iter_rows(d1, d2):
                w.writerow([
                    row.get("start", ""), row.get("end", ""),
                    row.get("duration_sec", ""), row.get("exe", ""),
                    row.get("category", ""), row.get("idle", ""),
                    row.get("context", "")
                ])

    def _export_html(self, d1: date, d2: date, out: Path):
        # Агрегация (без учёта контекста, только для статистики)
        by_category = defaultdict(int)
        by_exe      = defaultdict(int)
        by_hour     = defaultdict(int)   # 0..23
        idle_sec    = 0
        total_sec   = 0
        for row in self._iter_rows(d1, d2):
            try:
                dur = int(row.get("duration_sec", 0))
            except Exception:
                continue
            total_sec += dur
            if row.get("idle") == "1":
                idle_sec += dur
                continue
            exe = row.get("exe", "") or "(unknown)"
            cat = row.get("category", "") or "other"
            by_category[cat] += dur
            by_exe[exe] += dur
            try:
                start = datetime.fromisoformat(row.get("start", ""))
                by_hour[start.hour] += dur
            except Exception:
                pass

        def fmt_time(sec):
            h = sec // 3600
            m = (sec % 3600) // 60
            return f"{h}ч {m:02d}м" if h else f"{m}м"

        # SVG круговая диаграмма по категориям
        total_cat = sum(by_category.values()) or 1
        pie_parts = []
        colors = ["#4a90e2", "#e94e77", "#50c878", "#f5a623",
                  "#9b59b6", "#1abc9c", "#e67e22", "#95a5a6"]
        angle = 0
        cx, cy, r = 120, 120, 100
        legend = []
        for i, (cat, sec) in enumerate(sorted(by_category.items(), key=lambda x: -x[1])):
            frac = sec / total_cat
            a2 = angle + frac * 360
            large = 1 if frac > 0.5 else 0
            import math
            x1 = cx + r * math.cos(math.radians(angle - 90))
            y1 = cy + r * math.sin(math.radians(angle - 90))
            x2 = cx + r * math.cos(math.radians(a2 - 90))
            y2 = cy + r * math.sin(math.radians(a2 - 90))
            color = colors[i % len(colors)]
            if frac >= 0.999:
                pie_parts.append(f'<circle cx="{cx}" cy="{cy}" r="{r}" fill="{color}"/>')
            else:
                pie_parts.append(
                    f'<path d="M{cx},{cy} L{x1:.2f},{y1:.2f} '
                    f'A{r},{r} 0 {large} 1 {x2:.2f},{y2:.2f} Z" fill="{color}"/>'
                )
            legend.append((cat, sec, color, frac * 100))
            angle = a2

        pie_svg = f'<svg width="240" height="240" viewBox="0 0 240 240">{"".join(pie_parts)}</svg>'

        legend_html = "".join(
            f'<div class="lg"><span class="sw" style="background:{c}"></span>'
            f'{cat} — {fmt_time(s)} ({pct:.1f}%)</div>'
            for cat, s, c, pct in legend
        )

        # Столбиковая по часам
        max_hour = max(by_hour.values()) if by_hour else 1
        bars = []
        for h in range(24):
            v = by_hour.get(h, 0)
            height = int((v / max_hour) * 180) if max_hour else 0
            bars.append(
                f'<div class="bar-wrap"><div class="bar" style="height:{height}px" '
                f'title="{h:02d}:00 — {fmt_time(v)}"></div><div class="hr">{h:02d}</div></div>'
            )
        bars_html = "".join(bars)

        # Топ процессов
        top_exe = sorted(by_exe.items(), key=lambda x: -x[1])[:15]
        rows_html = "".join(
            f'<tr><td>{exe}</td><td>{fmt_time(sec)}</td>'
            f'<td>{self.categories.get(exe, "other")}</td></tr>'
            for exe, sec in top_exe
        )

        html = f"""<!doctype html>
<html lang="ru"><head><meta charset="utf-8">
<title>Отчёт активности {d1} — {d2}</title>
<style>
  body {{ font-family:-apple-system,Segoe UI,sans-serif; background:#1e1e1e;
         color:#eee; margin:0; padding:24px; }}
  h1 {{ margin:0 0 4px; font-size:20px; }}
  .sub {{ color:#999; margin-bottom:24px; }}
  .card {{ background:#252525; border:1px solid #444; border-radius:6px;
           padding:18px; margin-bottom:18px; }}
  .card h2 {{ margin:0 0 12px; font-size:15px; color:#ddd;
              border-bottom:1px solid #444; padding-bottom:6px; }}
  .row {{ display:flex; gap:24px; align-items:flex-start; flex-wrap:wrap; }}
  .lg {{ padding:4px 0; }}
  .sw {{ display:inline-block; width:12px; height:12px; margin-right:8px;
         vertical-align:middle; border-radius:2px; }}
  .bar-row {{ display:flex; gap:3px; align-items:flex-end; height:200px; }}
  .bar-wrap {{ flex:1; display:flex; flex-direction:column; align-items:center; }}
  .bar {{ width:100%; background:#0078d7; border-radius:2px 2px 0 0;
          min-height:1px; }}
  .hr {{ font-size:10px; color:#888; margin-top:4px; }}
  table {{ width:100%; border-collapse:collapse; }}
  th, td {{ text-align:left; padding:6px 8px; border-bottom:1px solid #333;
           font-size:13px; }}
  th {{ color:#bbb; font-weight:normal; }}
  .stats {{ display:flex; gap:32px; color:#ccc; }}
  .stats b {{ color:#fff; }}
</style></head>
<body>
  <h1>Отчёт активности</h1>
  <div class="sub">{d1} — {d2}</div>

  <div class="card">
    <h2>Общее</h2>
    <div class="stats">
      <div>Всего времени: <b>{fmt_time(total_sec)}</b></div>
      <div>Активность: <b>{fmt_time(total_sec - idle_sec)}</b></div>
      <div>Idle: <b>{fmt_time(idle_sec)}</b></div>
    </div>
  </div>

  <div class="card">
    <h2>По категориям</h2>
    <div class="row">
      {pie_svg}
      <div>{legend_html or "<i>нет данных</i>"}</div>
    </div>
  </div>

  <div class="card">
    <h2>По часам дня</h2>
    <div class="bar-row">{bars_html}</div>
  </div>

  <div class="card">
    <h2>Топ процессов</h2>
    <table>
      <tr><th>exe</th><th>время</th><th>категория</th></tr>
      {rows_html or "<tr><td colspan='3'><i>нет данных</i></td></tr>"}
    </table>
  </div>

</body></html>"""
        out.write_text(html, encoding="utf-8")

    # ------------------------------------------------------------------
    # Архивация
    # ------------------------------------------------------------------
    def _check_archive(self):
        if not self.archive_enabled:
            return
        today = date.today().isoformat()
        if self.last_archive_date == today:
            return
        try:
            # Архивируем всё старше 30 дней в zip по месяцам
            cutoff = date.today() - timedelta(days=30)
            by_month = defaultdict(list)
            for p in self.activity_dir().glob("*.csv"):
                try:
                    d = date.fromisoformat(p.stem)
                except Exception:
                    continue
                if d < cutoff:
                    by_month[f"{d.year}-{d.month:02d}"].append(p)
            for ym, files in by_month.items():
                zpath = self.activity_dir() / f"archive_{ym}.zip"
                with zipfile.ZipFile(zpath, "a", zipfile.ZIP_DEFLATED) as zf:
                    existing = set(zf.namelist())
                    for f in files:
                        if f.name not in existing:
                            zf.write(f, arcname=f.name)
                for f in files:
                    try:
                        f.unlink()
                    except Exception:
                        pass
            self.last_archive_date = today
            self._save_settings()
            if by_month:
                log(f"Archived: {sum(len(v) for v in by_month.values())} files")
            # Заодно чистим старые скриншоты
            try:
                self._cleanup_screenshots()
            except Exception as e:
                log(f"Screenshot cleanup failed: {e}")
        except Exception as e:
            log(f"Archive failed: {e}")

    # ------------------------------------------------------------------
    # Клавиатура: хук NumLock
    # ------------------------------------------------------------------
    def _on_key(self, event):
        if not self.running or event.name != "num lock":
            return

        now = time.time()
        if now - self._last_toggle < 0.5:
            return
        self._last_toggle = now

        if keyboard.is_pressed("shift"):
            self.calc_hotkey_enabled = not self.calc_hotkey_enabled
            self.act_calc_hotkey_enabled.setChecked(self.calc_hotkey_enabled)
            self._save_settings()
            log(f"Shift+NumLock -> calc hotkey: {self.calc_hotkey_enabled}")
            return

        if not self.calc_hotkey_enabled:
            return

        self._sig_toggle.emit()

    # ------------------------------------------------------------------
    # Логика запуска/скрытия приложения по NumLock
    # ------------------------------------------------------------------
    def _custom_exe_basename(self) -> str:
        """Basename кастомного exe (или '' если используется стандартный calc)."""
        if not self.calc_custom_cmd:
            return ""
        try:
            return Path(self.calc_custom_cmd).name.lower()
        except Exception:
            return ""

    def _find_target_hwnd(self):
        """Ищет окно целевого приложения (стандартный calc или custom exe)."""
        basename = self._custom_exe_basename()
        if basename:
            return find_hwnd_by_exe(basename)
        return find_calc_hwnd()

    def _launch_target(self):
        """Запускает целевое приложение."""
        if self.calc_custom_cmd:
            exe = self.calc_custom_cmd
            args = []
            if self.calc_custom_args.strip():
                # Простой split по пробелам — для большинства случаев хватит
                try:
                    import shlex
                    args = shlex.split(self.calc_custom_args, posix=False)
                except Exception:
                    args = self.calc_custom_args.split()
            cmd = [exe] + args
            log(f"Launching custom: {cmd}")
        else:
            cmd = [CALC_CMD]
            log("Launching calc…")
        try:
            subprocess.Popen(cmd, creationflags=subprocess.CREATE_NO_WINDOW)
        except Exception as e:
            log(f"Launch failed: {e}")
            try:
                self.tray.showMessage(APP_NAME,
                                      f"Не удалось запустить:\n{cmd[0]}\n{e}",
                                      QSystemTrayIcon.Warning, 3000)
            except Exception:
                pass

    def _do_toggle(self):
        log("Toggle")
        hwnd = self._find_target_hwnd()
        if not hwnd:
            self._launch_target()
            self._wait_for_calc()
        elif bool(IsIconic(hwnd)) or is_cloaked(hwnd):
            self._show(hwnd)
        else:
            self._hide(hwnd)
        QtCore.QTimer.singleShot(300, self._restore_numlock)

    def _wait_for_calc(self, ms: int = 200, attempts: int = 25):
        self._wait_n = attempts
        def _check():
            hwnd = self._find_target_hwnd()
            if hwnd:
                log("Target window appeared")
                self._show(hwnd)
                QtCore.QTimer.singleShot(300, self._restore_numlock)
            elif self._wait_n > 0:
                self._wait_n -= 1
                QtCore.QTimer.singleShot(ms, _check)
            else:
                log("Target window did not appear")
        QtCore.QTimer.singleShot(ms, _check)

    def _target_pos(self, hwnd) -> tuple:
        r  = get_rect(hwnd)
        ww = r.right - r.left
        wh = r.bottom - r.top
        sw = GetSystemMetrics(0)
        sh = GetSystemMetrics(1)
        if self.pos_mode == POS_CENTER:
            return (sw - ww) // 2, (sh - wh) // 2
        if self.pos_mode == POS_BOTTOM_RIGHT:
            return sw - ww - 12, sh - wh - 60
        return self.session_pos if self.session_pos else ((sw - ww) // 2, (sh - wh) // 2)

    def _show(self, hwnd):
        ShowWindow(hwnd, SW_RESTORE)
        ShowWindow(hwnd, SW_SHOW)
        x, y = self._target_pos(hwnd)
        SetWindowPos(hwnd, HWND_NOTOPMOST, x, y, 0, 0, SWP_NOSIZE | SWP_SHOWWINDOW)
        SetForegroundWindow(hwnd)
        apply_opacity(hwnd, self.opacity_pct)
        r = get_rect(hwnd)
        self.session_pos = (r.left, r.top)
        log(f"Shown at ({r.left},{r.top}) opacity={self.opacity_pct}%")

    def _hide(self, hwnd):
        r = get_rect(hwnd)
        self.session_pos = (r.left, r.top)
        ShowWindow(hwnd, SW_MINIMIZE)
        log(f"Minimized, pos={self.session_pos}")

    def _restore_numlock(self):
        try:
            if not (GetKeyState(VK_NUMLOCK) & 1):
                keybd_event(VK_NUMLOCK, 0, 0, 0)
                keybd_event(VK_NUMLOCK, 0, KEYEVENTF_KEYUP, 0)
        except Exception as e:
            log(f"NumLock restore error: {e}")


# === ИЗМЕНЕНИЕ: диалог настроек заметок ===
class NotesSettingsDialog(QDialog):
    def __init__(self, separator, newline_before, parent=None):
        super().__init__(parent)
        self.setWindowTitle("Настройки заметок")
        self.setWindowFlags(self.windowFlags() | Qt.WindowStaysOnTopHint)
        self.setMinimumWidth(350)
        self.setStyleSheet(DIALOG_QSS)

        layout = QVBoxLayout(self)
        layout.setSpacing(12)

        layout.addWidget(QLabel("Разделитель между датой и текстом:"))
        self.edit_sep = QLineEdit(separator)
        layout.addWidget(self.edit_sep)

        self.chk_newline = QCheckBox("Каждая заметка с новой строки")
        self.chk_newline.setChecked(newline_before)
        layout.addWidget(self.chk_newline)

        btn_box = QHBoxLayout()
        btn_box.addStretch()
        btn_ok = QPushButton("OK")
        btn_ok.clicked.connect(self.accept)
        btn_cancel = QPushButton("Отмена")
        btn_cancel.clicked.connect(self.reject)
        btn_box.addWidget(btn_ok)
        btn_box.addWidget(btn_cancel)
        layout.addLayout(btn_box)

    def get_values(self):
        return self.edit_sep.text(), self.chk_newline.isChecked()


