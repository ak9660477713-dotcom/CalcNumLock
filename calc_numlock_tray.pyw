    def _poll_foreground(self):
        """
        Фоновое отслеживание foreground-окна.
        Запоминает _last_user_hwnd = текущее окно пользователя, если оно
        не наше и не системное (tray/рабочий стол/launcher). Когда
        пользователь кликнет по tray-иконке, foreground станет
        Shell_TrayWnd — и мы уже НЕ перезапишем сохранённое значение.
        """
        try:
            hwnd = GetForegroundWindow()
            if not hwnd:
                return
            # Наше приложение не считаем
            pid = wintypes.DWORD()
            GetWindowThreadProcessId(hwnd, ctypes.byref(pid))
            if pid.value == self._our_pid:
                return
            # Системные/служебные классы не считаем
            cls = _get_class(hwnd)
            if cls in (
                "Shell_TrayWnd", "Shell_SecondaryTrayWnd",
                "NotifyIconOverflowWindow", "TrayNotifyWnd",
                "Progman", "WorkerW",           # рабочий стол
                "Windows.UI.Core.CoreWindow",   # Start/Search/ActionCenter
                "MultitaskingViewFrame",        # Alt+Tab view
            ):
                return
            self._last_user_hwnd = hwnd
        except Exception:
            pass

    def _on_tray_activated(self, reason):
        """
        Клик по иконке — показать меню. HWND активного окна уже сохранён
        фоновым поллером (_poll_foreground) и актуален на момент клика.
        """
        if reason in (QSystemTrayIcon.Trigger, QSystemTrayIcon.Context):
            self.tray.contextMenu().popup(QtGui.QCursor.pos())

