    def _apply_screenshot_timer(self):
        """Запускает/останавливает периодический таймер скриншотов."""
        if not hasattr(self, "shot_timer"):
            return
        if (self.screenshots_enabled and
                self.screenshot_mode == SHOT_MODE_WINDOW_PLUS_TIMER):
            interval_ms = max(1, self.screenshot_timer_interval_sec) * 1000
            self.shot_timer.setInterval(interval_ms)
            if not self.shot_timer.isActive():
                self.shot_timer.start()
            else:
                # Пересоздаём интервал на лету
                self.shot_timer.start(interval_ms)
            log(f"Shot timer active, every {self.screenshot_timer_interval_sec}s")
        else:
            if self.shot_timer.isActive():
                self.shot_timer.stop()
                log("Shot timer stopped")

    def _on_shot_timer_tick(self):
        """Периодический снимок независимо от смены окна."""
        # Не снимаем в idle — бессмысленно
        try:
            if get_idle_seconds() > self.idle_threshold_sec:
                return
        except Exception:
            pass
        self.take_screenshot("timer")

