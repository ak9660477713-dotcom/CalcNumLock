    # Слоты: калькулятор
    # ------------------------------------------------------------------
    def _set_pos_mode(self, mode: str):
        self.pos_mode = mode
        if mode != POS_LAST:
            self.session_pos = None
        self._save_settings()
        log(f"Position mode: {mode}")

    def _on_opacity(self, v: int):
        self.opacity_pct = v
        if hasattr(self, "lbl_opacity"):
            self.lbl_opacity.setText(f"Непрозрачность: {v}%")
        hwnd = self._find_target_hwnd()
        if hwnd:
