    # Скриншоты
    # ------------------------------------------------------------------
    def _effective_min_interval(self, reason: str) -> int:
        """
        Возвращает реальный min-интервал с учётом активного ВКС/медиа-окна.
        Для manual — 0 (всегда разрешено). Для timer/window_change — если
        активное окно в slowdown_exes и включено замедление, используем
        screenshot_slowdown_interval_sec.
        """
        if reason == "manual":
            return 0
        base = self.screenshot_min_interval_sec
        if reason == "timer":
            base = max(base, self.screenshot_timer_interval_sec)
        try:
            cur_exe = get_foreground_exe()
        except Exception:
            cur_exe = ""
        slow = self.screenshot_slowdown_interval_sec
        if (slow and cur_exe and
                cur_exe in [e.lower() for e in self.screenshot_slowdown_exes]):
            return max(base, slow)
        return base

    def take_screenshot(self, reason: str = "manual"):
        """
        Снимок всех подключённых мониторов (склеенный). С rate limit
        и уведомлением в трее. Не делает снимков, если активное окно
        в screenshot_exclusions.

        reason: "manual" | "window_change" | "timer"
        """
        if not self.screenshots_enabled and reason != "manual":
            return
        now = datetime.now()
        # Rate limit для автоматических снимков (с учётом slowdown)
        if reason != "manual" and self._last_shot_ts:
            elapsed = (now - self._last_shot_ts).total_seconds()
            min_int = self._effective_min_interval(reason)
            if elapsed < min_int:
                return
        # Исключения по текущему активному окну
        cur_exe = get_foreground_exe()
        if cur_exe in [e.lower() for e in self.screenshot_exclusions]:
            log(f"Screenshot skipped: {cur_exe} in exclusions")
            return
        try:
            screens = QGuiApplication.screens()
            if not screens:
                return

            # Объединённый bounding rect всех экранов в координатах
            # виртуального рабочего стола
            virt = QRect()
            for s in screens:
                virt = virt.united(s.geometry())

            # Итоговый холст размером со всю виртуальную область.
            # DPR берём максимальный, чтобы не потерять чёткость на HiDPI.
            dpr = max(s.devicePixelRatio() for s in screens)
            canvas = QPixmap(int(virt.width() * dpr), int(virt.height() * dpr))
            canvas.setDevicePixelRatio(dpr)
            canvas.fill(Qt.black)

            painter = QPainter(canvas)
            try:
                for s in screens:
                    g = s.geometry()
                    shot = s.grabWindow(0)  # снимок этого экрана
                    # offset относительно виртуального rect
                    painter.drawPixmap(g.x() - virt.x(), g.y() - virt.y(), shot)
            finally:
                painter.end()

            day_dir = self.screenshots_dir() / now.strftime("%Y-%m-%d")
            day_dir.mkdir(parents=True, exist_ok=True)
            fname = now.strftime("%H-%M-%S") + ".jpg"
            path = day_dir / fname

            # Применяем уменьшение размера (если < 100%)
            ds = max(25, min(100, self.screenshot_downscale_pct))
            if ds != 100:
                new_w = max(1, int(canvas.width() * ds / 100))
                new_h = max(1, int(canvas.height() * ds / 100))
                canvas = canvas.scaled(new_w, new_h,
                                       Qt.KeepAspectRatio,
                                       Qt.SmoothTransformation)

            canvas.save(str(path), "JPEG", self.screenshot_quality)
            self._last_shot_ts = now
            log(f"Screenshot saved: {path.name} ({reason}, "
                f"{len(screens)} screen{'s' if len(screens) > 1 else ''}, "
                f"downscale={ds}%)")
            # Индикация — уведомление в трее
            try:
                self.tray.showMessage(
                    APP_NAME,
                    f"Снимок: {now.strftime('%H:%M:%S')}",
                    QSystemTrayIcon.Information,
                    1500
                )
            except Exception:
                pass
        except Exception as e:
            log(f"Screenshot failed: {e}")

    def _cleanup_screenshots(self):
        """Удаляет старые скриншоты по дням и лимиту ГБ."""
        root = self.screenshots_dir()
        if not root.exists():
            return
        try:
            cutoff = date.today() - timedelta(days=self.screenshot_keep_days)
            for day_dir in list(root.iterdir()):
                if not day_dir.is_dir():
                    continue
                try:
                    d = date.fromisoformat(day_dir.name)
                    if d < cutoff:
                        for f in list(day_dir.iterdir()):
                            try:
                                f.unlink()
                            except Exception:
                                pass
                        try:
                            day_dir.rmdir()
                        except Exception:
                            pass
                except ValueError:
                    continue
            # Лимит ГБ
            all_files = sorted(root.rglob("*.jpg"), key=lambda f: f.stat().st_mtime)
            total = sum(f.stat().st_size for f in all_files)
            limit = self.screenshot_max_gb * 1024**3
            for f in all_files:
                if total <= limit:
                    break
                try:
                    total -= f.stat().st_size
                    f.unlink()
                except Exception:
                    pass
            log("Screenshots cleanup done")
        except Exception as e:
            log(f"Screenshot cleanup failed: {e}")

