class CategoriesDialog(QDialog):
    def __init__(self, categories: dict, category_names: list, parent=None):
        super().__init__(parent)
        self.setWindowTitle("Категории процессов")
        self.setWindowFlags(self.windowFlags() | Qt.WindowStaysOnTopHint)
        self.setMinimumSize(460, 380)
        self.setStyleSheet(DIALOG_QSS)

        self.result_categories = dict(categories)
        self.category_names = list(category_names)

        lay = QVBoxLayout(self)
        lay.setContentsMargins(16, 16, 16, 16)
        lay.setSpacing(10)

        lay.addWidget(QLabel("Сопоставление exe → категория:"))

        self.table = QTableWidget(0, 3)
        self.table.setHorizontalHeaderLabels(["exe", "категория", ""])
        self.table.horizontalHeader().setSectionResizeMode(0, QHeaderView.Stretch)
        self.table.horizontalHeader().setSectionResizeMode(1, QHeaderView.ResizeToContents)
        self.table.horizontalHeader().setSectionResizeMode(2, QHeaderView.ResizeToContents)
        self.table.verticalHeader().setVisible(False)
        self.table.setEditTriggers(QAbstractItemView.NoEditTriggers)
        lay.addWidget(self.table)

        for exe, cat in sorted(categories.items()):
            self._add_row(exe, cat)

        # Добавление новой строки
        add_row = QHBoxLayout()
        self.inp_exe = QLineEdit()
        self.inp_exe.setPlaceholderText("например, chrome.exe")
        self.inp_cat = QComboBox()
        self.inp_cat.addItems(self.category_names)
        btn_add = QPushButton("+ Добавить")
        btn_add.clicked.connect(self._on_add)
        add_row.addWidget(self.inp_exe, 2)
        add_row.addWidget(self.inp_cat, 1)
        add_row.addWidget(btn_add)
        lay.addLayout(add_row)

        lbl = QLabel(f"Доступные категории: {', '.join(self.category_names)}")
        lbl.setStyleSheet("color:#999; font-size:11px;")
        lay.addWidget(lbl)

        # Кнопки
        btn_row = QHBoxLayout()
        btn_row.addStretch()
        b_cancel = QPushButton("Отмена")
        b_cancel.clicked.connect(self.reject)
        b_save = QPushButton("Сохранить")
        b_save.clicked.connect(self._on_save)
        btn_row.addWidget(b_cancel)
        btn_row.addWidget(b_save)
        lay.addLayout(btn_row)

    def _add_row(self, exe: str, cat: str):
        r = self.table.rowCount()
        self.table.insertRow(r)
        self.table.setItem(r, 0, QTableWidgetItem(exe))
        combo = QComboBox()
        combo.addItems(self.category_names)
        if cat in self.category_names:
            combo.setCurrentText(cat)
        self.table.setCellWidget(r, 1, combo)
        btn_del = QPushButton("×")
        btn_del.setFixedWidth(28)
        btn_del.clicked.connect(lambda _, row=r: self._on_delete(row))
        self.table.setCellWidget(r, 2, btn_del)

    def _on_add(self):
        exe = self.inp_exe.text().strip().lower()
        if not exe:
            return
        if not exe.endswith(".exe"):
            exe += ".exe"
        # Проверка дубликата
        for r in range(self.table.rowCount()):
            if self.table.item(r, 0).text() == exe:
                QMessageBox.information(self, APP_NAME, f"{exe} уже в списке")
                return
        self._add_row(exe, self.inp_cat.currentText())
        self.inp_exe.clear()

    def _on_delete(self, row: int):
        # row — индекс на момент создания кнопки, он может устареть. Найти по кнопке.
        sender = self.sender()
        for r in range(self.table.rowCount()):
            if self.table.cellWidget(r, 2) is sender:
                self.table.removeRow(r)
                return

    def _on_save(self):
        result = {}
        for r in range(self.table.rowCount()):
            exe = self.table.item(r, 0).text().strip().lower()
            combo = self.table.cellWidget(r, 1)
            if exe and combo:
                result[exe] = combo.currentText()
        self.result_categories = result
        self.accept()


