        b_cancel.clicked.connect(self.reject)
        b_save = QPushButton("Экспортировать")
        b_save.clicked.connect(self._on_export)
        btn_row.addWidget(b_cancel)
        btn_row.addWidget(b_save)
        lay.addLayout(btn_row)

    def _on_export(self):
        self.result_from = self.d_from.date().toPyDate()
        self.result_to   = self.d_to.date().toPyDate()
        if self.result_from > self.result_to:
            QMessageBox.warning(self, APP_NAME, "Начало периода позже конца")
            return
        self.result_format = "html" if self.grp_fmt.checkedId() == 0 else "csv"
        default_name = f"activity_{self.result_from}_{self.result_to}.{self.result_format}"
        path, _ = QFileDialog.getSaveFileName(
            self, "Сохранить отчёт",
            str(Path.home() / "Documents" / default_name),
            f"{self.result_format.upper()} (*.{self.result_format})"
        )
        if not path:
            return
        self.result_path = path
        self.accept()


# ---------------------------------------------------------------------------
# Трекер активности (вынесен в отдельный класс для чистоты)
# ---------------------------------------------------------------------------
class ActivityTracker:
    """
    Опрашивает активное окно по QTimer и ведёт CSV с интервалами.
    Запись происходит при смене exe или при смене idle-статуса.
    """

    def __init__(self, app):
        self.app = app  # ссылка на CalcTrayApp для доступа к конфигу
        self.timer = QTimer()
        self.timer.setInterval(self.app.activity_poll_sec * 1000)
        self.timer.timeout.connect(self._tick)

        self.current_exe = ""
        self.current_idle = False
        self.current_context = ""
        self.segment_start = None  # datetime начала текущего сегмента

    def start(self):
        log("Activity tracker started")
        self.segment_start = datetime.now()
        self.current_exe = get_foreground_exe()
        self.current_idle = False
        self.current_context = self.app.get_window_context(self.current_exe, get_foreground_hwnd())
        self.timer.start()

    def stop(self):
        self.timer.stop()
        self._flush_segment(datetime.now())
        log("Activity tracker stopped")

    def is_paused(self) -> bool:
        s = self.app.activity_paused_until
        if not s:
            return False
        try:
            until = datetime.fromisoformat(s)
            return datetime.now() < until
        except Exception:
            return False

    def _tick(self):
        if not self.app.activity_enabled or self.is_paused():
            return
        now = datetime.now()
        idle_sec = get_idle_seconds()
        idle = idle_sec > self.app.idle_threshold_sec
        hwnd = get_foreground_hwnd() if not idle else 0
        exe = "" if idle else get_foreground_exe()

        exe_changed = (exe != self.current_exe)
        state_changed = exe_changed or (idle != self.current_idle)

        # Запись происходит при смене exe или idle-флага
        if state_changed:
            self._flush_segment(now)
            if exe_changed and exe and not idle:
                # Скриншот (с rate limit внутри)
                try:
                    self.app.take_screenshot("window_change")
                except Exception as e:
                    log(f"take_screenshot raised: {e}")
                # Контекст окна (заголовок, URL, чат)
                self.current_context = self.app.get_window_context(exe, hwnd)
            else:
                # при переходе в idle или обратно без смены exe контекст остаётся прежним
                pass
            self.current_exe = exe
            self.current_idle = idle
            self.segment_start = now

    def _flush_segment(self, end_time: datetime):
        if not self.segment_start:
            return
        duration = (end_time - self.segment_start).total_seconds()
        if duration < 1:
            return
        category = self.app.categories.get(self.current_exe, "other") \
                   if self.current_exe else ""
        row = [
            self.segment_start.isoformat(timespec="seconds"),
            end_time.isoformat(timespec="seconds"),
            int(duration),
            self.current_exe,
            category,
            1 if self.current_idle else 0,
            self.current_context,
        ]
        path = self.app.activity_csv_path(self.segment_start.date())
        try:
            path.parent.mkdir(parents=True, exist_ok=True)
            new_file = not path.exists()
            with open(path, "a", newline="", encoding="utf-8") as f:
                w = csv.writer(f)
                if new_file:
                    w.writerow(["start", "end", "duration_sec", "exe", "category", "idle", "context"])
                w.writerow(row)
        except Exception as e:
            log(f"CSV write failed: {e}")

    def reload_interval(self):
        """Применить изменённый интервал опроса."""
        self.timer.setInterval(self.app.activity_poll_sec * 1000)


