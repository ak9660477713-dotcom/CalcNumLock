        lay.addWidget(QLabel("Формат:"))
        self.grp_fmt = QButtonGroup(self)
        rb_html = QRadioButton("HTML (с графиками)")
        rb_csv  = QRadioButton("CSV")
        rb_html.setChecked(True)
        self.grp_fmt.addButton(rb_html, 0)
        self.grp_fmt.addButton(rb_csv, 1)
        lay.addWidget(rb_html)
        lay.addWidget(rb_csv)

        btn_row = QHBoxLayout()
        btn_row.addStretch()
