    # ------------------------------------------------------------------
    # Контекст окна (заголовок, URL, чат)
    # ------------------------------------------------------------------
    def get_window_context(self, exe: str, hwnd: int) -> str:
        """
        Возвращает строку контекста в зависимости от выбранного режима.
        """
        if self.context_mode == CTX_MODE_OFF:
            return ""

        # Получаем заголовок окна (всегда)
        title = ""
        if hwnd:
            n = GetWindowTextLengthW(hwnd)
            if n:
                buf = ctypes.create_unicode_buffer(n + 1)
                GetWindowTextW(hwnd, buf, n + 1)
                title = buf.value.strip()

        if self.context_mode == CTX_MODE_TITLE:
            return title

        # Расширенный режим (требует .home и uia)
        if self.context_mode == CTX_MODE_EXTENDED and IS_HOME and HAS_UIA:
            if exe in BROWSER_EXES:
                url = get_browser_url(exe, hwnd)
                if url:
                    return f"URL: {url}"
            elif exe in TELEGRAM_EXES:
                chat = get_telegram_chat(exe, hwnd)
                if chat:
                    return f"Telegram: {chat}"
            # Здесь можно добавить получение пути к документу для Office и т.п.
            # Пока оставляем только заголовок.
        return title

    # ------------------------------------------------------------------
    # Единицы измерения
    # ------------------------------------------------------------------
    def _ensure_units_file(self):
        if not UNITS_FILE.exists():
            try:
                UNITS_FILE.write_text(DEFAULT_UNITS_TEXT, encoding="utf-8")
            except Exception as e:
                log(f"Create units file failed: {e}")

    def _load_units_file(self):
        self._ensure_units_file()
        self.units_by_category = {}

        try:
            lines = UNITS_FILE.read_text(encoding="utf-8").splitlines()
        except Exception as e:
            log(f"Read units file failed: {e}")
            return

        for i, raw in enumerate(lines, start=1):
            line = raw.strip()
            if not line or line.startswith("#"):
                continue

            parts = [p.strip() for p in raw.split("|", 2)]
            if len(parts) == 2:
                category, label = parts
                value = label
            elif len(parts) == 3:
                category, label, value = parts
            else:
                log(f"Bad units line {i}: {raw}")
                continue

            if not category or not label:
                log(f"Empty category/label in units line {i}: {raw}")
                continue

            self.units_by_category.setdefault(category, []).append({
                "label": label,
                "value": value or label,
            })

    def _reload_units_file(self):
        self._load_units_file()
        self._rebuild_units_menu()
        try:
            self.tray.showMessage(
                APP_NAME,
                "Меню единиц перечитано из units_menu.txt",
                QSystemTrayIcon.Information,
                1500
            )
        except Exception:
            pass
        log("Units menu reloaded")

    def _open_units_file(self):
        self._ensure_units_file()
        try:
            os.startfile(str(UNITS_FILE))
        except Exception as e:
            log(f"Open units file failed: {e}")

    def _get_clipboard_text(self) -> str:
        try:
            cb = QApplication.clipboard()
            return cb.text() or ""
        except Exception:
            return ""

    def _set_clipboard_text(self, text: str):
        try:
            QApplication.clipboard().setText(text)
        except Exception as e:
            log(f"Set clipboard failed: {e}")

    # === Автовставка единиц измерения ===
    def _paste_to_previous_window(self) -> bool:
        """
        Активирует сохранённое _last_user_hwnd и шлёт Ctrl+V через SendInput.
        Выполнение асинхронное: сначала закрываем меню и отдаём управление
        event-loop'у, потом через ~120мс активируем окно и вставляем.
        """
        hwnd = self._last_user_hwnd
        if not hwnd:
            log("Paste: no saved HWND")
            return False
        if not user32.IsWindow(hwnd):
            log(f"Paste: saved HWND {hwnd} is not a window anymore")
            self._last_user_hwnd = 0
            return False

        # Закрываем любые открытые попап-меню нашего tray, чтобы Qt не
        # держал input-фокус. Это критично — иначе SetForegroundWindow
        # не сработает пока активен popup.
        try:
            cm = self.tray.contextMenu()
            if cm:
                cm.close()
        except Exception:
            pass

        def _do_paste():
            try:
                title = _get_text(hwnd)[:60]
                ok_fg = _force_foreground(hwnd)
                # Небольшая задержка, чтобы Windows успел сменить фокус
                time.sleep(0.05)
                ok_send = _send_ctrl_v()
                log(f"Paste → hwnd={hwnd} title={title!r} "
                    f"fg={ok_fg} send={ok_send}")
            except Exception as e:
                log(f"Paste async error: {e}")

        QTimer.singleShot(120, _do_paste)
        return True

    def _apply_unit(self, unit_value: str):
        current = self._get_clipboard_text()

        if self.unit_mode == UNIT_MODE_COPY:
            result = unit_value
        else:
            if not current:
                result = unit_value
            elif current[-1] in (' ', '\t', '\n', '\u00A0'):
                result = current + unit_value          # уже есть разделитель
            else:
                result = current + ' ' + unit_value    # добавить пробел

        self._set_clipboard_text(result)

        # Лаконичное уведомление
        try:
            self.tray.showMessage(
                APP_NAME,
                f"Скопировано: {result}",
                QSystemTrayIcon.Information,
                1200
            )
        except Exception:
            pass

        # Автовставка (Ctrl+V) в предыдущее активное окно, если включено
        pasted = False
        if self.unit_auto_paste:
            pasted = self._paste_to_previous_window()

        # Закрыть меню если автовставка сработала (Windows всё равно закроет
        # popup при SetForegroundWindow) или если stay-open выключен.
        if pasted or not self.unit_keep_menu_open:
            try:
                self.tray.contextMenu().close()
            except Exception:
                pass

        log(f"Unit applied: mode={self.unit_mode}, value={unit_value!r}, "
            f"auto_paste={self.unit_auto_paste}, pasted={pasted}, "
            f"keep_open={self.unit_keep_menu_open}")

    def _set_unit_mode(self, mode: str):
        if mode not in (UNIT_MODE_APPEND, UNIT_MODE_COPY):
            return
        self.unit_mode = mode
        if hasattr(self, "_unit_mode_actions"):
            for a in self._unit_mode_actions:
                a.setChecked(a.data() == mode)
        self._save_settings()
        log(f"Unit mode: {mode}")

    def _toggle_unit_auto_paste(self):
        self.unit_auto_paste = not self.unit_auto_paste
        if hasattr(self, "act_unit_auto_paste"):
            self.act_unit_auto_paste.setChecked(self.unit_auto_paste)
        self._save_settings()
        log(f"Unit auto_paste: {self.unit_auto_paste}")

    def _toggle_unit_keep_open(self):
        self.unit_keep_menu_open = not self.unit_keep_menu_open
        if hasattr(self, "act_unit_keep_open"):
            self.act_unit_keep_open.setChecked(self.unit_keep_menu_open)
        self._save_settings()
        # Перестроить меню чтобы убрать/вернуть stay_open
        self._rebuild_units_menu()
        log(f"Unit keep_menu_open: {self.unit_keep_menu_open}")

    def _rebuild_units_menu(self):
        if not hasattr(self, "units_menu"):
            return

        self.units_menu.clear()

        # Пункты единиц. Помечаем property stay_open — StayOpenMenu
        # не будет закрывать меню при клике по такому пункту.
        stay_open = self.unit_keep_menu_open
        for category, items in self.units_by_category.items():
            header = QAction(f"── {category} ──", self)
            header.setEnabled(False)
            font = header.font()
            font.setBold(True)
            header.setFont(font)
            self.units_menu.addAction(header)

            for item in items:
                act = QAction(item["label"], self)
                if stay_open:
                    act.setProperty("stay_open", True)
                act.triggered.connect(lambda _, v=item["value"]: self._apply_unit(v))
                self.units_menu.addAction(act)

            self.units_menu.addSeparator()

        # Удаляем последний лишний разделитель, если есть
        actions = self.units_menu.actions()
        if actions and actions[-1].isSeparator():
            self.units_menu.removeAction(actions[-1])

        # Раздел с настройками
        self.units_menu.addSeparator()

        # Подменю «Поведение»
        mode_menu = QMenu("Поведение", self)
        mode_menu.setStyleSheet(self._menu_css())
        grp_mode = QActionGroup(self)
        self._unit_mode_actions = []

        for label, mode in [
            ("Дописать в буфер", UNIT_MODE_APPEND),
            ("Скопировать ед. изм. в буфер", UNIT_MODE_COPY),
        ]:
            act = QAction(label, self)
            act.setCheckable(True)
            act.setChecked(self.unit_mode == mode)
            act.setData(mode)
            act.triggered.connect(lambda _, m=mode: self._set_unit_mode(m))
            grp_mode.addAction(act)
            mode_menu.addAction(act)
            self._unit_mode_actions.append(act)

        mode_menu.addSeparator()

        self.act_unit_auto_paste = QAction("Вставлять в поле курсора (Ctrl+V)", self)
        self.act_unit_auto_paste.setCheckable(True)
        self.act_unit_auto_paste.setChecked(self.unit_auto_paste)
        self.act_unit_auto_paste.triggered.connect(self._toggle_unit_auto_paste)
        mode_menu.addAction(self.act_unit_auto_paste)

        self.act_unit_keep_open = QAction("Не закрывать меню", self)
        self.act_unit_keep_open.setCheckable(True)
        self.act_unit_keep_open.setChecked(self.unit_keep_menu_open)
        self.act_unit_keep_open.triggered.connect(self._toggle_unit_keep_open)
        mode_menu.addAction(self.act_unit_keep_open)

        self.units_menu.addMenu(mode_menu)

        self.units_menu.addSeparator()

        act_reload = QAction("Перечитать units_menu.txt", self)
        act_reload.triggered.connect(self._reload_units_file)
        self.units_menu.addAction(act_reload)

        act_open = QAction("Открыть units_menu.txt", self)
        act_open.triggered.connect(self._open_units_file)
        self.units_menu.addAction(act_open)

    # ------------------------------------------------------------------
    # Быстрые заметки
    # ------------------------------------------------------------------
    @staticmethod
    def _rtf_escape(s: str) -> str:
        """Экранирует строку для вставки в RTF (кириллица через \\u)."""
        out = []
        for ch in s:
            if ch in ('\\', '{', '}'):
                out.append('\\' + ch)
            elif ch == '\n':
                out.append('\\line ')
            elif ord(ch) < 128:
                out.append(ch)
            else:
                code = ord(ch)
                if code > 32767:
                    code -= 65536
                out.append(f'\\u{code}?')
        return ''.join(out)

    # === ИЗМЕНЕНИЕ: использование новых настроек в _append_note ===
    def _append_note(self, text: str):
        """Дописывает заметку в файл указанного формата."""
        text = text.strip()
        if not text:
            return False
        try:
            path = Path(self.notes_path) if self.notes_path else DEFAULT_NOTES_FILE
            path.parent.mkdir(parents=True, exist_ok=True)
            ts = datetime.now().strftime("%Y-%m-%d %H:%M")
            fmt = self.notes_format

            line_content = f"{ts}{self.notes_separator}{text}"
            if fmt == NOTE_FMT_MD:
                line = f"- {line_content}\n"
            elif fmt == NOTE_FMT_TXT:
                line = f"{line_content}\n"
            elif fmt == NOTE_FMT_RTF:
                entry = self._rtf_escape(line_content) + "\\line\n"
                # ... логика записи RTF с учётом newline (см. ниже)
            else:
                return False

            # Проверяем, нужно ли добавить перевод строки перед записью
            prepend_newline = False
            if self.notes_newline_before and path.exists() and path.stat().st_size > 0:
                prepend_newline = True

            if fmt == NOTE_FMT_RTF:
                # RTF обрабатываем отдельно (вставка перед закрывающей '}')
                if path.exists():
                    content = path.read_text(encoding="utf-8", errors="ignore")
                    idx = content.rfind('}')
                    if idx > 0:
                        # Добавляем перевод строки, если нужно (в RTF это \line)
                        if prepend_newline:
                            entry = "\\line\n" + entry
                        new_content = content[:idx] + entry + content[idx:]
                    else:
                        new_content = content + entry
                    path.write_text(new_content, encoding="utf-8")
                else:
                    header = ('{\\rtf1\\ansi\\ansicpg1251\\deff0'
                              '{\\fonttbl{\\f0\\fnil\\fcharset204 Segoe UI;}}'
                              '\\f0\\fs22\n')
                    path.write_text(header + entry + '}', encoding="utf-8")
            else:
                with open(path, "a", encoding="utf-8") as f:
                    if prepend_newline:
                        f.write("\n")
                    f.write(line)

            try:
                self.tray.showMessage(
                    APP_NAME,
                    f"Заметка → {path.name}",
                    QSystemTrayIcon.Information,
                    1200
                )
            except Exception:
                pass
            log(f"Note appended to {path.name} ({fmt}): {text[:60]!r}")
            return True
        except Exception as e:
            log(f"Append note failed: {e}")
            try:
                self.tray.showMessage(APP_NAME,
                                      f"Ошибка записи заметки:\n{e}",
                                      QSystemTrayIcon.Warning, 3000)
            except Exception:
                pass
            return False

    def _on_note_enter(self):
        """Обработчик Enter в поле заметки."""
        if not hasattr(self, "note_input"):
            return
        text = self.note_input.text()
        if not text.strip():
            return
        if self._append_note(text):
            self.note_input.clear()
        # Меню остаётся открытым — QLineEdit внутри QWidgetAction
        # не закрывает QMenu при Enter/клике.

    def _choose_notes_path(self):
        start_dir = str(Path(self.notes_path).parent) if self.notes_path else str(DATA_DIR)
        start_name = Path(self.notes_path).name if self.notes_path else f"notes.{self.notes_format}"
        path, _ = QFileDialog.getSaveFileName(
            self, "Файл заметок",
            str(Path(start_dir) / start_name),
            "Markdown (*.md);;Text (*.txt);;Rich Text (*.rtf);;Все файлы (*)"
        )
        if not path:
            return
        self.notes_path = path
        # Синхронизировать формат с расширением
        ext = Path(path).suffix.lower().lstrip(".")
        if ext in (NOTE_FMT_MD, NOTE_FMT_TXT, NOTE_FMT_RTF):
            self.notes_format = ext
            if hasattr(self, "_notes_fmt_actions"):
                for a in self._notes_fmt_actions:
                    a.setChecked(a.data() == self.notes_format)
        self._save_settings()
        self._refresh_notes_label()
        log(f"Notes path: {self.notes_path}, format: {self.notes_format}")

    def _set_notes_format(self, fmt: str):
        if fmt not in (NOTE_FMT_MD, NOTE_FMT_TXT, NOTE_FMT_RTF):
            return
        self.notes_format = fmt
        if hasattr(self, "_notes_fmt_actions"):
            for a in self._notes_fmt_actions:
                a.setChecked(a.data() == fmt)
        # Предложим обновить расширение в пути, если не совпадает
        if self.notes_path:
            p = Path(self.notes_path)
            cur_ext = p.suffix.lower().lstrip(".")
            if cur_ext != fmt:
                self.notes_path = str(p.with_suffix("." + fmt))
                self._refresh_notes_label()
        self._save_settings()
        log(f"Notes format: {fmt}")

    def _open_notes_file(self):
        path = Path(self.notes_path) if self.notes_path else DEFAULT_NOTES_FILE
        try:
            if not path.exists():
                path.parent.mkdir(parents=True, exist_ok=True)
                path.touch()
            os.startfile(str(path))
        except Exception as e:
            log(f"Open notes failed: {e}")

    def _open_notes_folder(self):
        path = Path(self.notes_path) if self.notes_path else DEFAULT_NOTES_FILE
        try:
            os.startfile(str(path.parent))
        except Exception as e:
            log(f"Open notes folder failed: {e}")

    def _refresh_notes_label(self):
        """Обновляет placeholder/подсказку в поле заметок."""
        if hasattr(self, "note_input") and self.note_input:
            try:
                self.note_input.setPlaceholderText(
                    f"Заметка → {Path(self.notes_path).name} ({self.notes_format}) "
                    f"[{self.notes_separator}]"
                )
            except Exception:
                pass

