    def _toggle_calc_hotkey_enabled(self):
        self.calc_hotkey_enabled = not self.calc_hotkey_enabled
        self.act_calc_hotkey_enabled.setChecked(self.calc_hotkey_enabled)
        self._save_settings()
        log(f"Calc hotkey enabled: {self.calc_hotkey_enabled}")

    def _exit(self):
        self.running = False
        log("Exiting")
        try:
            self.tracker.stop()
        except Exception:
            pass
        try:
            if hasattr(self, "shot_timer") and self.shot_timer.isActive():
                self.shot_timer.stop()
        except Exception:
            pass
        try:
            keyboard.unhook_all()
        except Exception:
            pass
        self.tray.hide()
        QApplication.quit()

    def _pick_calc_exe(self):
        start_dir = (str(Path(self.calc_custom_cmd).parent)
                     if self.calc_custom_cmd and Path(self.calc_custom_cmd).exists()
                     else str(Path.home()))
        path, _ = QFileDialog.getOpenFileName(
            self, "Выберите exe приложения",
            start_dir,
            "Исполняемые файлы (*.exe);;Все файлы (*)"
        )
        if not path:
            return
        # Опционально — аргументы
        args, ok = QInputDialog.getText(
            self, "Аргументы запуска",
            "Аргументы командной строки (необязательно):",
            QLineEdit.Normal, self.calc_custom_args
        )
        self.calc_custom_cmd = path
        if ok:
            self.calc_custom_args = args.strip()
        self._save_settings()
        self._refresh_calc_exe_label()
        basename = self._custom_exe_basename()
        log(f"Custom calc: {path} (basename={basename}, args={self.calc_custom_args!r})")
        try:
            self.tray.showMessage(
                APP_NAME,
                f"NumLock → {Path(path).name}",
                QSystemTrayIcon.Information, 2000
            )
        except Exception:
            pass

    def _reset_calc_exe(self):
        self.calc_custom_cmd = ""
        self.calc_custom_args = ""
        self._save_settings()
        self._refresh_calc_exe_label()
        if hasattr(self, "_calc_exe_actions"):
            for a in self._calc_exe_actions:
                a.setChecked(a.data() == ("custom" if self.calc_custom_cmd else "default"))
        log("Custom calc reset to Windows Calculator")

    def _refresh_calc_exe_label(self):
        if not hasattr(self, "act_calc_exe_current"):
            return
        if self.calc_custom_cmd:
            name = Path(self.calc_custom_cmd).name
            self.act_calc_exe_current.setText(f"Текущий: {name}")
        else:
            self.act_calc_exe_current.setText("Текущий: calc.exe (Windows)")
        # Обновить radio-индикацию
        if hasattr(self, "_calc_exe_actions"):
            target = "custom" if self.calc_custom_cmd else "default"
            for a in self._calc_exe_actions:
                a.setChecked(a.data() == target)

    def _set_calc_exe_mode(self, mode: str):
        """Radio: 'default' (calc.exe) или 'custom' (пиккер если ещё не задан)."""
        if mode == "default":
            self._reset_calc_exe()
        else:
            # custom — если ещё не задан, вызываем пиккер
            if not self.calc_custom_cmd:
                self._pick_calc_exe()
            else:
                # Уже задан — просто убеждаемся что radio в положении custom
                self._refresh_calc_exe_label()
        self.running = False
        log("Exiting")
        try:
            self.tracker.stop()
        except Exception:
            pass
        try:
            keyboard.unhook_all()
        except Exception:
            pass
        self.tray.hide()
        QApplication.quit()

