        self.screenshot_keep_days   = int(data.get("screenshot_keep_days", 14))
        self.screenshot_max_gb      = float(data.get("screenshot_max_gb", 2.0))
        self.screenshot_exclusions  = list(data.get("screenshot_exclusions", self.screenshot_exclusions))
        # Контекст окна
