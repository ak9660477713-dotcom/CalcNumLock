    def _set_context_mode(self, mode: str):
        if mode not in (CTX_MODE_OFF, CTX_MODE_TITLE, CTX_MODE_EXTENDED):
            return
        self.context_mode = mode
        if hasattr(self, "_ctx_mode_actions"):
            for a in self._ctx_mode_actions:
                a.setChecked(a.data() == mode)
        self._save_settings()
        log(f"Context mode: {mode}")
        # При смене режима принудительно обновим контекст текущего окна
        if self.activity_enabled and self.tracker:
            hwnd = get_foreground_hwnd()
            exe = get_foreground_exe()
            self.tracker.current_context = self.get_window_context(exe, hwnd)

    def _toggle_activity(self):
        self.activity_enabled = not self.activity_enabled
        self.act_activity_enabled.setChecked(self.activity_enabled)
        if self.activity_enabled:
            self.tracker.start()
        else:
            self.tracker.stop()
        self._save_settings()
        log(f"Activity tracker: {self.activity_enabled}")

    def _pause_label(self) -> str:
        if not self.activity_paused_until:
            return "Пауза: выкл"
        try:
            until = datetime.fromisoformat(self.activity_paused_until)
            if datetime.now() >= until:
                return "Пауза: выкл"
            return f"Пауза до {until.strftime('%H:%M')}"
        except Exception:
            return "Пауза"

    def _refresh_pause_label(self):
        self.pause_menu.setTitle(self._pause_label())
        # Автоматически снимаем паузу, когда истёк срок
        if self.activity_paused_until:
            try:
                until = datetime.fromisoformat(self.activity_paused_until)
                if datetime.now() >= until:
                    self.activity_paused_until = ""
                    self._save_settings()
            except Exception:
                self.activity_paused_until = ""

    def _pause_for(self, minutes: int):
        until = datetime.now() + timedelta(minutes=minutes)
        self.activity_paused_until = until.isoformat(timespec="seconds")
        # Сбросить текущий сегмент, чтобы пауза разделила записи
        if self.activity_enabled:
            self.tracker._flush_segment(datetime.now())
            self.tracker.segment_start = datetime.now()
            self.tracker.current_exe = ""
            self.tracker.current_idle = False
            self.tracker.current_context = ""
        self._save_settings()
        self._refresh_pause_label()
        log(f"Paused until {self.activity_paused_until}")

    def _pause_off(self):
        self.activity_paused_until = ""
        self._save_settings()
        self._refresh_pause_label()
        log("Pause off")

