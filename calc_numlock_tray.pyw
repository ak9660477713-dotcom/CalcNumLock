_uia_cache = {"hwnd": 0, "url": "", "chat": "", "ts": 0.0}


def get_browser_url(exe: str, hwnd: int) -> str:
    """
    Адресная строка активной вкладки через UIA. Кэш 2 сек.
    Работает только если IS_HOME и HAS_UIA.
    """
    if not (IS_HOME and HAS_UIA):
        return ""
    if exe not in BROWSER_EXES or not hwnd:
        return ""
    now = time.time()
    if _uia_cache["hwnd"] == hwnd and (now - _uia_cache["ts"]) < 2.0:
        return _uia_cache["url"]
    url = ""
    try:
        ctrl = uia.ControlFromHandle(hwnd)
        if ctrl:
            edit = ctrl.EditControl(searchDepth=24)
            if edit.Exists(0.2, 0.05):
                v = edit.GetValuePattern().Value
                if v:
                    url = v
    except Exception:
        url = ""
    _uia_cache.update({"hwnd": hwnd, "url": url, "ts": now})
    return url


def get_telegram_chat(exe: str, hwnd: int) -> str:
    """
    Название текущего чата в Telegram Desktop через UIA.
    Ищем заголовок активного чата (у Telegram это элемент рядом с
    областью сообщений). Fallback — заголовок окна после " — Telegram".
    """
    if not (IS_HOME and HAS_UIA):
        return ""
    if exe not in TELEGRAM_EXES or not hwnd:
        return ""
    chat = ""
    try:
        # Fallback через заголовок: "Название чата — Telegram"
        n = GetWindowTextLengthW(hwnd)
        if n:
            buf = ctypes.create_unicode_buffer(n + 1)
            GetWindowTextW(hwnd, buf, n + 1)
            title = buf.value
            # В Telegram Desktop заголовок может быть "Имя — Telegram"
            # или просто "Telegram" если чат не открыт
            if title and "telegram" in title.lower():
                parts = title.rsplit("—", 1)
                if len(parts) == 2:
                    chat = parts[0].strip()
    except Exception:
        chat = ""
    return chat


# ---------------------------------------------------------------------------
# StayOpenMenu — меню, не закрывающееся по клику на action с флагом stay_open
# ---------------------------------------------------------------------------
class StayOpenMenu(QMenu):
    """
    QMenu, который не закрывается, если кликнули на action,
    помеченный property('stay_open', True). Для всех остальных
    actions поведение стандартное.
    """
    def mouseReleaseEvent(self, event):
        action = self.activeAction()
        if (action and action.isEnabled() and action.menu() is None
                and action.property("stay_open")):
            # Триггерим, но не закрываем меню
            action.trigger()
            return
        super().mouseReleaseEvent(event)


# === ИЗМЕНЕНИЕ: класс SmartMenu для управления направлением раскрытия ===
class SmartMenu(StayOpenMenu):
    """Меню, которое раскрывается влево, если находится в правой половине экрана."""
    def popup(self, pos):
        screen_geo = QGuiApplication.primaryScreen().geometry()
        menu_width = self.sizeHint().width()
        # Если точка pos.x + ожидаемая ширина меню выходит за середину экрана, раскрываем влево
        if pos.x() + menu_width > screen_geo.width() // 2:
            pos.setX(pos.x() - menu_width)
        super().popup(pos)


