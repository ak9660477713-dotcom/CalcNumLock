    # ----- Вкладка «Пути» -----
    def _build_paths_tab(self) -> QWidget:
        w = QWidget()
        lay = QVBoxLayout(w)
        lay.setContentsMargins(12, 12, 12, 12)
        lay.setSpacing(8)

        lab = QLabel("Все файлы программы. Кнопка справа открывает "
                     "нужную папку в проводнике.")
        lab.setWordWrap(True)
        lab.setStyleSheet("color:#aaa; font-size:11px;")
        lay.addWidget(lab)

        def _row(title: str, path: Path, kind: str = "file"):
            line = QFrame()
            line.setStyleSheet(
                "QFrame { background:#252525; border:1px solid #3a3a3a;"
                "         border-radius:4px; }")
            h = QHBoxLayout(line)
            h.setContentsMargins(10, 8, 10, 8)
            h.setSpacing(8)
            tv = QVBoxLayout()
            tv.setSpacing(2)
            t = QLabel(f"<b>{title}</b>")
            p = QLabel(str(path))
            p.setStyleSheet("color:#aaa; font-family:Consolas, monospace; font-size:11px;")
            p.setTextInteractionFlags(Qt.TextSelectableByMouse)
            tv.addWidget(t); tv.addWidget(p)
            h.addLayout(tv, 1)
            if kind == "file":
                b_open = QPushButton("Открыть")
                b_open.setFixedWidth(90)
                b_open.clicked.connect(lambda: self._open_target(path, "file"))
                h.addWidget(b_open)
            b_folder = QPushButton("Папка")
            b_folder.setFixedWidth(70)
            b_folder.clicked.connect(lambda: self._open_target(path, "folder"))
            h.addWidget(b_folder)
            return line

        lay.addWidget(_row("Скрипт программы",
                           Path(sys.argv[0]).resolve(), "file"))
        lay.addWidget(_row("Настройки (config)",
                           CONFIG_FILE, "file"))
        lay.addWidget(_row("Лог",
                           DATA_DIR / LOG_FILE, "file"))
        lay.addWidget(_row("Единицы измерения",
                           UNITS_FILE, "file"))
        lay.addWidget(_row("Файл заметок",
                           Path(self.app.notes_path), "file"))
        lay.addWidget(_row("CSV трекера",
                           self.app.activity_dir(), "folder"))
        lay.addWidget(_row("Папка скриншотов",
                           self.app.screenshots_dir(), "folder"))

        lay.addStretch()
        return w

    def _open_target(self, path: Path, kind: str):
        try:
            p = Path(path)
            if kind == "folder" or not p.exists() and not p.suffix:
                # Папка (или путь похож на папку)
                p.mkdir(parents=True, exist_ok=True)
                os.startfile(str(p))
            else:
                if kind == "file" and not p.exists():
                    # Открываем родительскую
                    p.parent.mkdir(parents=True, exist_ok=True)
                    os.startfile(str(p.parent))
                    return
                if kind == "folder":
                    os.startfile(str(p))
                else:
                    # File — открыть родителя, а не сам файл (чтобы не запускался exe)
                    os.startfile(str(p.parent))
        except Exception as e:
            QMessageBox.warning(self, APP_NAME, f"Не удалось открыть: {e}")

    # ----- Кнопки диалога -----
    def _on_reset_all(self):
        ans = QMessageBox.question(
            self, APP_NAME,
            "Сбросить все настройки к значениям по умолчанию?\n"
            "Это не удалит данные трекера, категории, "
            "список единиц, заметки и скриншоты.",
            QMessageBox.Yes | QMessageBox.No, QMessageBox.No
        )
        if ans == QMessageBox.Yes:
            self.app._reset_settings()
            self.accept()

    def _on_ok(self):
        a = self.app
        # --- Общие ---
        a.calc_hotkey_enabled = self.chk_numlock_enabled.isChecked()
        if hasattr(a, "act_calc_hotkey_enabled"):
            a.act_calc_hotkey_enabled.setChecked(a.calc_hotkey_enabled)
        if self.cmb_calc_mode.currentData() == "custom":
            a.calc_custom_cmd  = self.le_calc_exe.text().strip()
            a.calc_custom_args = self.le_calc_args.text().strip()
        else:
            a.calc_custom_cmd  = ""
            a.calc_custom_args = ""
        a.pos_mode = self.cmb_pos_mode.currentData()
        if a.pos_mode != POS_LAST:
            a.session_pos = None
        new_op = int(self.spn_opacity.value())
        if new_op != a.opacity_pct:
            a.opacity_pct = new_op
            if hasattr(a, "sld_opacity"):
                a.sld_opacity.setValue(new_op)
            hwnd = a._find_target_hwnd()
            if hwnd:
                apply_opacity(hwnd, new_op)

        # --- Единицы ---
        a.unit_mode = UNIT_MODE_APPEND if self.rb_unit_append.isChecked() else UNIT_MODE_COPY
        a.unit_auto_paste     = self.chk_unit_paste.isChecked()
        a.unit_keep_menu_open = self.chk_unit_keep.isChecked()

        # --- Заметки ---
        a.notes_path = self.le_notes_path.text().strip() or str(DEFAULT_NOTES_FILE)
        a.notes_format = self.cmb_notes_fmt.currentData() or NOTE_FMT_MD
        sep = self.le_notes_sep.text()
        a.notes_separator = sep if sep else " — "

        # --- Скриншоты ---
        was_enabled = a.screenshots_enabled
        a.screenshots_enabled = self.chk_shots_on.isChecked()
        a.screenshot_mode = (SHOT_MODE_WINDOW_CHANGE
                             if self.rb_shot_win.isChecked()
                             else SHOT_MODE_WINDOW_PLUS_TIMER)
        a.screenshot_min_interval_sec = int(self.spn_shot_min.value())
        a.screenshot_timer_interval_sec = int(self.spn_shot_timer.value())
        a.screenshot_slowdown_interval_sec = int(self.spn_shot_slow.value())
        a.screenshot_quality = int(self.spn_shot_q.value())
        a.screenshot_downscale_pct = int(self.spn_shot_scale.value())
        a.screenshot_keep_days = int(self.spn_shot_days.value())
        a.screenshot_max_gb = float(self.spn_shot_gb.value())

        # --- Трекер ---
        want_track = self.chk_track_on.isChecked()
        if want_track != a.activity_enabled:
            a.activity_enabled = want_track
            if hasattr(a, "act_activity_enabled"):
                a.act_activity_enabled.setChecked(want_track)
            try:
                if want_track:
                    a.tracker.start()
                else:
                    a.tracker.stop()
            except Exception:
                pass
        a.activity_poll_sec = int(self.spn_poll.value())
        a.idle_threshold_sec = int(self.spn_idle.value())
        try:
            a.tracker.reload_interval()
        except Exception:
            pass

        if self.rb_ctx_off.isChecked():
            a.context_mode = CTX_MODE_OFF
        elif self.rb_ctx_ext.isChecked() and self.rb_ctx_ext.isEnabled():
            a.context_mode = CTX_MODE_EXTENDED
        else:
            a.context_mode = CTX_MODE_TITLE

        # Сохраняем + применяем производные вещи
        a._save_settings()
        try:
            a._apply_screenshot_timer()
        except Exception:
            pass
        try:
            a._rebuild_units_menu()
        except Exception:
            pass
        try:
            a._refresh_notes_label()
        except Exception:
            pass
        log("Settings saved via SettingsDialog")
        self.accept()


