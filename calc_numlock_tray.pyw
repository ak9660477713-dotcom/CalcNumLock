        self.activity_poll_sec      = int(data.get("activity_poll_sec", 5))
        self.idle_threshold_sec     = int(data.get("idle_threshold_sec", 120))
        self.activity_paused_until  = data.get("activity_paused_until", "")
        self.categories             = dict(data.get("categories", {}))
        self.category_names         = list(data.get("category_names", DEFAULT_CATEGORY_NAMES))
        self.archive_enabled        = bool(data.get("archive_enabled", True))
        self.last_archive_date      = data.get("last_archive_date", "")
        # Скриншоты
        self.screenshots_enabled    = bool(data.get("screenshots_enabled", False))
        mode = data.get("screenshot_mode", SHOT_MODE_WINDOW_CHANGE)
        if mode not in (SHOT_MODE_WINDOW_CHANGE, SHOT_MODE_WINDOW_PLUS_TIMER):
            mode = SHOT_MODE_WINDOW_CHANGE
