def load_embedded_icon() -> QtGui.QIcon:
    """Загружает иконку из вшитого base64."""
    try:
        raw = base64.b64decode(ICON_B64)
        pix = QtGui.QPixmap()
        if pix.loadFromData(raw, "ICO"):
            return QtGui.QIcon(pix)
    except Exception:
        pass
    # Фоллбэк — красный квадрат
    pix = QtGui.QPixmap(32, 32)
    pix.fill(QtGui.QColor("#e05"))
    return QtGui.QIcon(pix)



class RECT(ctypes.Structure):
    _fields_ = [("left", ctypes.c_long), ("top", ctypes.c_long),
                ("right", ctypes.c_long), ("bottom", ctypes.c_long)]


class LASTINPUTINFO(ctypes.Structure):
    _fields_ = [("cbSize", wintypes.UINT), ("dwTime", wintypes.DWORD)]


# === Структуры для SendInput (автовставка единиц) ===
# Важно: union должен содержать ВСЕ варианты ввода (mouse/keyboard/hardware),
# иначе sizeof(INPUT) будет меньше ожидаемого и SendInput молча вернёт 0.
class MOUSEINPUT(ctypes.Structure):
    _fields_ = [("dx", wintypes.LONG), ("dy", wintypes.LONG),
                ("mouseData", wintypes.DWORD), ("dwFlags", wintypes.DWORD),
                ("time", wintypes.DWORD),
                ("dwExtraInfo", ctypes.POINTER(ctypes.c_ulong))]

class KEYBDINPUT(ctypes.Structure):
    _fields_ = [("wVk", wintypes.WORD),
                ("wScan", wintypes.WORD),
                ("dwFlags", wintypes.DWORD),
                ("time", wintypes.DWORD),
                ("dwExtraInfo", ctypes.POINTER(ctypes.c_ulong))]

class HARDWAREINPUT(ctypes.Structure):
    _fields_ = [("uMsg", wintypes.DWORD),
                ("wParamL", wintypes.WORD), ("wParamH", wintypes.WORD)]

class _INPUT_UNION(ctypes.Union):
    _fields_ = [("mi", MOUSEINPUT),
                ("ki", KEYBDINPUT),
                ("hi", HARDWAREINPUT)]

class INPUT(ctypes.Structure):
    _anonymous_ = ("_u",)
    _fields_ = [("type", wintypes.DWORD), ("_u", _INPUT_UNION)]

INPUT_KEYBOARD = 1
KEYEVENTF_KEYDOWN = 0x0000
KEYEVENTF_KEYUP   = 0x0002
VK_CONTROL = 0x11
VK_V = 0x56

# Параметры SendInput по MSDN
user32.SendInput.argtypes = [wintypes.UINT, ctypes.POINTER(INPUT), ctypes.c_int]
user32.SendInput.restype = wintypes.UINT


def _send_ctrl_v():
    """
    Отправляет Ctrl+V через SendInput.
    Возвращает True, если все 4 события приняты системой.
    """
    arr = (INPUT * 4)()
    # Ctrl down
    arr[0].type = INPUT_KEYBOARD
    arr[0].ki.wVk = VK_CONTROL
    # V down
    arr[1].type = INPUT_KEYBOARD
    arr[1].ki.wVk = VK_V
    # V up
    arr[2].type = INPUT_KEYBOARD
    arr[2].ki.wVk = VK_V
    arr[2].ki.dwFlags = KEYEVENTF_KEYUP
    # Ctrl up
    arr[3].type = INPUT_KEYBOARD
    arr[3].ki.wVk = VK_CONTROL
    arr[3].ki.dwFlags = KEYEVENTF_KEYUP
    sent = user32.SendInput(4, arr, ctypes.sizeof(INPUT))
    if sent != 4:
        err = ctypes.get_last_error()
        log(f"SendInput sent={sent}/4, GetLastError={err}, "
            f"sizeof(INPUT)={ctypes.sizeof(INPUT)}")
        return False
    return True


def _force_foreground(hwnd) -> bool:
    """
    Пытается сделать hwnd активным окном, обходя защиту от SetForegroundWindow.
    Техника AttachThreadInput, которая работает в большинстве случаев.
    """
    try:
        if not hwnd:
            return False
        if IsIconic(hwnd):
            ShowWindow(hwnd, SW_RESTORE)
        # Прямая попытка — обычно работает, т.к. наш процесс сам foreground
        if user32.SetForegroundWindow(hwnd):
            return True
        # Fallback: привязываем input-очереди
        cur_fg = GetForegroundWindow()
        if not cur_fg:
            return False
        fg_tid = user32.GetWindowThreadProcessId(cur_fg, None)
        our_tid = kernel32.GetCurrentThreadId()
        if fg_tid and fg_tid != our_tid:
            user32.AttachThreadInput(our_tid, fg_tid, True)
            try:
                user32.BringWindowToTop(hwnd)
                user32.SetForegroundWindow(hwnd)
            finally:
                user32.AttachThreadInput(our_tid, fg_tid, False)
        return GetForegroundWindow() == hwnd
    except Exception as e:
        log(f"_force_foreground error: {e}")
        return False


